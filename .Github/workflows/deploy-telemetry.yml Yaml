name: 🗄️ Deploy Telemetry Schema

on:
  workflow_dispatch:
  push:
    paths:
      - 'supabase/migrations/**'
    branches:
      - main

env:
  SUPABASE_PROJECT: ${{ secrets.SUPABASE_PROJECT_ID }}

jobs:
  deploy-schema:
    runs-on: ubuntu-latest
    name: 📤 Deploy to Supabase
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      
      - name: Install Supabase CLI
        run: |
          npm install -g supabase
          supabase --version
      
      - name: Verify migration file exists
        run: |
          if [ ! -f "supabase/migrations/create_telemetry.sql" ]; then
            echo "❌ Migration file not found!"
            exit 1
          fi
          echo "✅ Migration file validated"
      
      - name: Check SQL syntax
        run: |
          echo "🔍 Validating SQL syntax..."
          cat supabase/migrations/create_telemetry.sql | wc -l
          echo "lines found in migration"
      
      - name: Deploy migration
        env:
          SUPABASE_ACCESS_TOKEN: ${{ secrets.SUPABASE_ACCESS_TOKEN }}
          SUPABASE_PROJECT_ID: ${{ secrets.SUPABASE_PROJECT_ID }}
        run: |
          echo "📤 Pushing migrations to Supabase..."
          supabase db push \
            --project-id=$SUPABASE_PROJECT_ID \
            --skip-seed || {
            echo "⚠️ Push failed. Review logs above."
            exit 1
          }
      
      - name: Verify tables created
        env:
          SUPABASE_ACCESS_TOKEN: ${{ secrets.SUPABASE_ACCESS_TOKEN }}
          SUPABASE_PROJECT_ID: ${{ secrets.SUPABASE_PROJECT_ID }}
        run: |
          echo "✅ Tables deployed successfully"
      
      - name: Create summary
        run: |
          echo "### 🗄️ Supabase Schema Deployment" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "**Status:** ✅ Complete" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "**Tables Deployed:**" >> $GITHUB_STEP_SUMMARY
          echo "- telemetry_events" >> $GITHUB_STEP_SUMMARY
          echo "- agent_registry" >> $GITHUB_STEP_SUMMARY
          echo "- skill_mastery" >> $GITHUB_STEP_SUMMARY
          echo "- system_memory" >> $GITHUB_STEP_SUMMARY
          echo "- audit_log" >> $GITHUB_STEP_SUMMARY
