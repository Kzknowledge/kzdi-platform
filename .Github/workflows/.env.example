# ============================================================================
# KZDI ENVIRONMENT TEMPLATE
# Copy to .env and fill with your actual values (NEVER commit .env)
# ============================================================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Node Environment
NODE_ENV=production

# Application Settings
APP_NAME=kzdi-platform
APP_VERSION=1.0.0

# Telemetry (optional)
ENABLE_TELEMETRY=true
LOG_LEVEL=info

# Feature Flags
ENABLE_MCP_EXECUTOR=true
ENABLE_SKILL_REGISTRY=true
ENABLE_AGENT_RUNTIME=true
