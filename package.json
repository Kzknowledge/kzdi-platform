{
  "scripts": {
    "build": "tsc",

    "test": "jest",
    "test:all": "npm run test:mcp && npm run test:graph && npm run test:vector && npm run test:telemetry && npm run test:health",

    "test:jest": "jest --runInBand",

    "test:mcp": "ts-node tests/mcp/mcp.lifecycle.test.ts",
    "test:graph": "ts-node tests/mcp/graph.validation.test.ts",
    "test:vector": "ts-node tests/mcp/vector.validation.test.ts",
    "test:telemetry": "ts-node tests/mcp/telemetry.validation.test.ts",
    "test:health": "ts-node tests/mcp/system.health.test.ts",

    "test:unit": "jest --runInBand",
    "test:ci": "npm run test:all"
  }
}
