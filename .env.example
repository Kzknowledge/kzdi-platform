============================================================================

KZDI PRODUCTION ENVIRONMENT CONFIG

DO NOT COMMIT THIS FILE

============================================================================

System: KZDI MCP + Supabase Telemetry + Make.com Orchestration

Mode: MVP Validation / Free Tier Optimized

============================================================================

=========================

SUPABASE CORE

=========================

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

Database (ONLY if using direct Postgres - optional)

SUPABASE_DB_PASSWORD=your_db_password_here
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432

=========================

NODE RUNTIME

=========================

NODE_ENV=production
NODE_VERSION=20

=========================

KZDI APPLICATION CORE

=========================

APP_NAME=kzdi-platform
APP_VERSION=2.5.0-stable

MCP EXECUTION FLAGS

ENABLE_MCP_EXECUTOR=true
ENABLE_AGENT_REGISTRY=true
ENABLE_SKILL_RUNTIME=true
ENABLE_TELEMETRY=true

=========================

TELEMETRY CONFIGURATION

=========================

LOG_LEVEL=info
TELEMETRY_TABLE=telemetry_events
EVENT_MODE=structured_json

=========================

MAKE.COM INTEGRATION

=========================

MAKE_WEBHOOK_URL=https://hook.make.com/your-webhook-id
ENABLE_MAKE_BUFFER=true
MAKE_RETRY_COUNT=3

=========================

TELEGRAM NOTIFICATIONS

=========================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

=========================

EDGE FUNCTION SECURITY (EDGE-001 FIX)

=========================

EDGE_SECRET=your_edge_secret_key
ENABLE_EDGE_AUTH=true

=========================

FEATURE FLAGS (MVP CONTROL)

=========================

ENABLE_TALENT_OS_MVP=true
ENABLE_EMPLOYER_SIGNALS=true
ENABLE_STAKEHOLDER_TRACKING=true

=========================

PERFORMANCE / COST CONTROL

=========================

TOKEN_MINIMIZATION_MODE=true
ENABLE_VERBOSE_LOGS=false
BATCH_EVENT_WRITES=true

============================================================================

END CONFIG

============================================================================
